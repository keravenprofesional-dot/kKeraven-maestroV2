# Copiar este archivo a ".env" y completar con valores reales.
# ".env" nunca se sube a git (ver .gitignore).

DATABASE_URL=postgresql://kerplus:CAMBIAR_CLAVE@db:5432/kerplus
# true si DATABASE_URL apunta a un host remoto que exige SSL (ej. Supabase).
# false para Postgres local/Docker en la misma red interna.
DB_SSL=false
# Máximo de conexiones simultáneas del pool hacia Postgres. Default 20 si no
# se define. Revisar el límite real del plan (Supabase: Database > Settings
# > Connection pooling) antes de subirlo mucho más.
DB_POOL_MAX=20
SESSION_SECRET=CAMBIAR_POR_UNA_CADENA_LARGA_Y_ALEATORIA
COOKIE_SECURE=false
PORT=3000

# Cifra las claves de API de Sarah (IA) guardadas en la base de datos
# (tabla config_ia) -- nunca se guardan en texto plano. Debe ser una
# cadena hexadecimal de 32 bytes (64 caracteres). Generar con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IA_CIFRADO_SECRET=CAMBIAR_POR_64_CARACTERES_HEXADECIMALES

# Postgres (usadas por docker-compose.yml para crear el contenedor de base de datos)
POSTGRES_USER=kerplus
POSTGRES_PASSWORD=CAMBIAR_CLAVE
POSTGRES_DB=kerplus
